<Page x:Class="PocketMC.Desktop.Features.InstanceCreation.NewInstancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="New Instance">

    <Grid Margin="28,20,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Width="{Binding ElementName=ContentLayoutRoot, Path=ActualWidth}"
              MaxWidth="980"
              HorizontalAlignment="Left"
              Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <ui:Button Content="Back"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon ArrowLeft24}"
                           MinWidth="88"
                           Margin="0,0,14,0"
                           Click="BtnBack_Click"/>

                <ui:TextBlock FontTypography="Title"
                              Text="Create a New Instance"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="BtnBrowseModpacks"
                           Content="Browse Modpacks"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Box24}"
                           Margin="0,0,8,0"
                           Click="BtnBrowseModpacks_Click"/>
                <ui:Button x:Name="BtnImportZip"
                           Content="Import Zip"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon Folder24}"
                           Click="BtnImportZip_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              x:Name="ContentLayoutRoot"
              MaxWidth="980"
              HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="FormColumnDefinition" Width="*"/>
                <ColumnDefinition x:Name="GapColumnDefinition" Width="20"/>
                <ColumnDefinition x:Name="SideColumnDefinition" Width="268"/>
            </Grid.ColumnDefinitions>

            <ui:Card x:Name="FormCard"
                     Grid.Row="0"
                     Grid.Column="0"
                     Padding="22"
                     Margin="0">
                <StackPanel x:Name="InputsPanel">
                    <TextBlock Text="Basics"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="Server Name"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ui:TextBox x:Name="TxtName"
                                PlaceholderText="My Cool Server"
                                Margin="0,0,0,14"/>

                    <TextBlock Text="Description"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ui:TextBox x:Name="TxtDescription"
                                PlaceholderText="What this instance is for"
                                Margin="0,0,0,18"/>

                    <TextBlock Text="Server Type"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ComboBox x:Name="CmbServerType"
                              Margin="0,0,0,12"
                              MinHeight="40"
                              SelectionChanged="CmbServerType_SelectionChanged">
                        <ComboBoxItem Content="Vanilla" IsSelected="True"/>
                        <ComboBoxItem Content="Paper"/>
                        <ComboBoxItem Content="Fabric"/>
                        <ComboBoxItem Content="Forge"/>
                    </ComboBox>

                    <TextBlock x:Name="TxtForgeWarning"
                               Visibility="Collapsed"
                               Foreground="#F9E2AF"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>

                    <CheckBox x:Name="ChkShowSnapshots"
                              Content="Show snapshots and pre-releases"
                              Margin="0,0,0,18"
                              Checked="ChkShowSnapshots_Changed"
                              Unchecked="ChkShowSnapshots_Changed"/>

                    <TextBlock Text="Minecraft Version"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ComboBox x:Name="CmbVersion"
                              Margin="0,0,0,12"
                              MinHeight="40"
                              DisplayMemberPath="Id"
                              SelectionChanged="CmbVersion_SelectionChanged"/>

                    <StackPanel x:Name="LoaderVersionPanel" Visibility="Collapsed">
                        <TextBlock Text="Loader Version"
                                   Margin="0,0,0,6"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ComboBox x:Name="CmbLoaderVersion"
                                  Margin="0,0,0,12"
                                  MinHeight="40"
                                  DisplayMemberPath="Version"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtVersionState"
                               Text="Choose a server type to load available versions."
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ui:Card>

            <ui:Card x:Name="ComplianceCard"
                     Grid.Row="0"
                     Grid.Column="2"
                     Padding="20"
                     VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Compliance"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,16"/>

                    <CheckBox x:Name="ChkAcceptEula"
                              Margin="0,0,0,12"
                              Checked="ChkAcceptEula_Changed"
                              Unchecked="ChkAcceptEula_Changed">
                        <TextBlock Text="I accept the Minecraft End User License Agreement"
                                   TextWrapping="Wrap"
                                   FontSize="13"/>
                    </CheckBox>

                    <TextBlock FontSize="12"
                               Opacity="0.88"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="24,0,0,0">
                        <Run Text="PocketMC will write eula.txt automatically after the server jar finishes downloading. Review "/>
                        <Hyperlink NavigateUri="https://aka.ms/MinecraftEULA"
                                   RequestNavigate="MinecraftEulaLink_RequestNavigate">Mojang's EULA</Hyperlink>
                        <Run Text=" before creating the instance."/>
                    </TextBlock>
                </StackPanel>
            </ui:Card>
        </Grid>

        <Border Grid.Row="2"
                x:Name="ProgressOverlay"
                Visibility="Collapsed"
                Width="{Binding ElementName=ContentLayoutRoot, Path=ActualWidth}"
                Background="#10FFFFFF"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                HorizontalAlignment="Left"
                Margin="0,16,0,14">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <ui:ProgressRing Width="18"
                                     Height="18"
                                     IsIndeterminate="True"
                                     Margin="0,0,8,0"/>
                    <TextBlock Text="Preparing your server files..."
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               FontWeight="SemiBold"/>
                </StackPanel>
                <ProgressBar x:Name="PrgDownload"
                             Minimum="0"
                             Maximum="100"
                             Height="6"
                             Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtProgress"
                           Text="Waiting for download..."
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3"
              Width="{Binding ElementName=ContentLayoutRoot, Path=ActualWidth}"
              HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    x:Name="ErrorCallout"
                    Visibility="Collapsed"
                    Background="#26F44336"
                    BorderBrush="#66F44336"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12"
                    Margin="0,0,16,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="8"
                            Height="8"
                            Background="#FFB4AB"
                            CornerRadius="4"
                            Margin="0,5,10,0"
                            VerticalAlignment="Top"/>
                    <TextBlock x:Name="TxtError"
                               Foreground="#FFE8E6"
                               TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <ui:Button x:Name="BtnCancel"
                           Content="Cancel"
                           Appearance="Secondary"
                           Margin="0,0,8,0"
                           Click="BtnBack_Click"/>
                <ui:Button x:Name="BtnCreate"
                           Content="Create and Download"
                           Appearance="Primary"
                           Icon="{ui:SymbolIcon ArrowDownload24}"
                           Click="BtnCreate_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
