<Page x:Class="PocketMC.Desktop.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Dashboard">
    
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Inverse bool converter -->
        <Style x:Key="HiddenWhenRunning" TargetType="FrameworkElement">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowRunningControls}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenRunning" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowRunningControls}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>
    
    <Grid Margin="24" AllowDrop="True" Drop="Page_Drop" DragOver="Page_DragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0">


            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <ui:TextBlock FontTypography="Title" Text="Instances" Foreground="White" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <ui:Button Content="New Instance" Icon="{ui:SymbolIcon Add24}" Appearance="Primary" Click="BtnNewInstance_Click" Cursor="Hand" Margin="0,0,8,0"/>
                <ui:Button Content="Import Modpack" Icon="{ui:SymbolIcon FolderZip24}" Appearance="Secondary" Click="BtnImportModpack_Click" Cursor="Hand" Margin="0,0,8,0"/>
                <ui:Button Content="Browse Modpacks" Icon="{ui:SymbolIcon Globe24}" Appearance="Secondary" Click="BtnBrowseModpacks_Click" Cursor="Hand"/>
            </StackPanel>

            <!-- Playit Health Banner (NET-05, D-02) -->
            <Border x:Name="PlayitStatusBanner" Visibility="Collapsed" Background="#44F44336" BorderBrush="#88F44336" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Symbol="Warning24" Margin="0,0,12,0" Foreground="Red" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtPlayitStatus" Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Foreground="White">
                        <Run Text="⚠ Playit.gg Status" FontWeight="Bold"/>
                        <LineBreak/>
                        <Run x:Name="TxtPlayitDetail" Text="Token invalid — re-link account to restore tunnel access."/>
                    </TextBlock>
                    <ui:Button Grid.Column="2" x:Name="BtnFixPlayit" Content="Fix" Appearance="Secondary" Padding="12,4" Click="BtnFixPlayit_Click" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Left">
                <ItemsControl x:Name="InstanceGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Outer Border for green glow — ui:Card ignores BorderBrush overrides -->
                            <Border Margin="0,0,16,16" CornerRadius="8" Padding="0" Width="340" MinWidth="280" MinHeight="180">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ui:Card Cursor="Hand" Padding="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                    <Grid Margin="16">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/> <!-- Title & Menu -->
                                            <RowDefinition Height="Auto"/> <!-- Description -->
                                            <RowDefinition Height="Auto"/> <!-- Status & Tunnel Pill -->
                                            <RowDefinition Height="Auto"/> <!-- Running Metrics Panel -->
                                            <RowDefinition Height="*"/>    <!-- Spacer -->
                                            <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                                        </Grid.RowDefinitions>
                                
                                <!-- Title row (Row 0) -->
                                <Grid Grid.Row="0" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <ui:TextBlock Grid.Column="0" FontTypography="Subtitle" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    
                                    <ui:Button Grid.Column="1" Appearance="Transparent" Icon="{ui:SymbolIcon MoreVertical24}" 
                                               Click="BtnMoreOptions_Click" Cursor="Hand" Padding="6,4" Margin="0,-6,-6,0" VerticalAlignment="Top">
                                        <ui:Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Rename Instance" Click="RenameInstance_Click" />
                                                <Separator/>
                                                <MenuItem Header="Copy Crash Report" Click="CopyCrashReport_Click" />
                                                <MenuItem Header="Open Instance Folder" Click="BtnOpenFolder_Click" />
                                                <Separator/>
                                                <MenuItem Header="Delete Instance" Click="DeleteInstance_Click" />
                                            </ContextMenu>
                                        </ui:Button.ContextMenu>
                                    </ui:Button>
                                </Grid>
                                
                                <!-- Description (Row 1) -->
                                <ui:TextBlock Grid.Row="1" FontTypography="Caption" Text="{Binding Description}" 
                                              Foreground="Silver" Height="34"
                                              TextWrapping="Wrap" Margin="0,0,0,12" TextTrimming="CharacterEllipsis"/>
                                              
                                <!-- Status & Tunnel Pill (Row 2) -->
                                <Grid Grid.Row="2" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="{Binding StatusText}" 
                                               Foreground="{Binding StatusColor}" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                               
                                    <Border Grid.Column="1" Background="#2089B4FA" CornerRadius="10" Padding="8,3"
                                            Cursor="Hand" Visibility="{Binding HasTunnelAddress, Converter={StaticResource BoolToVis}}">
                                        <Border.InputBindings>
                                            <MouseBinding Gesture="LeftClick" Command="{x:Null}"/>
                                        </Border.InputBindings>
                                        <TextBlock Text="{Binding TunnelAddress}" FontSize="10" 
                                                   Foreground="#89B4FA" FontWeight="SemiBold"
                                                   MouseLeftButtonDown="TunnelPill_MouseDown"/>
                                    </Border>
                                </Grid>
                                
                                <!-- Running metrics panel (Row 3, hidden when stopped) -->
                                <Grid Grid.Row="3" Style="{StaticResource VisibleWhenRunning}" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CpuText}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding RamText}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                                    </StackPanel>
                                    
                                    <!-- Player count -->
                                    <TextBlock Grid.Column="2" Text="{Binding PlayerStatus}" FontSize="11" FontWeight="Medium" 
                                               Foreground="{Binding StatusColor}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>

                                <!-- Action buttons (Row 5) -->
                                <Grid Grid.Row="5" Margin="0,8,0,0">
                                    <!-- STOPPED state -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Style="{StaticResource HiddenWhenRunning}">
                                        <ui:Button Content="Start" Appearance="Primary" Margin="0,0,4,0"
                                                   Icon="{ui:SymbolIcon Play24}" Click="BtnStart_Click" Cursor="Hand"/>
                                        <ui:Button Content="Logs" Appearance="Secondary" Margin="0,0,4,0"
                                                   Icon="{ui:SymbolIcon WindowConsole20}" Click="BtnConsole_Click" Cursor="Hand"/>
                                        <ui:Button Content="Settings" Appearance="Secondary" Margin="0,0,4,0"
                                                   Icon="{ui:SymbolIcon Settings24}" Click="BtnManage_Click" Cursor="Hand"/>
                                        <ui:Button Icon="{ui:SymbolIcon Folder24}" Click="BtnOpenFolder_Click" Cursor="Hand"/>
                                    </StackPanel>
                                    
                                    <!-- RUNNING state -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Style="{StaticResource VisibleWhenRunning}">
                                        <ui:Button Content="Console" Appearance="Primary" Margin="0,0,4,0"
                                                   Icon="{ui:SymbolIcon WindowConsole20}" Click="BtnConsole_Click" Cursor="Hand"/>
                                        <ui:Button Content="Settings" Appearance="Secondary" Margin="0,0,4,0"
                                                   Icon="{ui:SymbolIcon Settings24}" Click="BtnManage_Click" Cursor="Hand"/>
                                        <ui:Button Content="{Binding StopButtonText}" Appearance="Danger" 
                                                   Icon="{ui:SymbolIcon Stop24}" Click="BtnStop_Click" Cursor="Hand"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </ui:Card>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="TxtEmpty" Text="No servers yet. Click 'New Instance' to get started." 
                           Foreground="Silver" HorizontalAlignment="Left" Margin="40" FontSize="14" Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
