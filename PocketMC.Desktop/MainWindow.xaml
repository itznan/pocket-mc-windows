<ui:FluentWindow x:Class="PocketMC.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:PocketMC.Desktop.Views"
        mc:Ignorable="d"
        Title="PocketMC Desktop" Height="650" Width="1050"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/icon.ico"
        Loaded="Window_Loaded">

    <Grid>
        <!-- LAYER 0: Win10 fallback Mica background (hidden on Win11) -->
        <Image x:Name="MicaFallbackBackground"
               Stretch="UniformToFill"
               RenderOptions.BitmapScalingMode="HighQuality"
               IsHitTestVisible="False"
               Visibility="Collapsed"/>

        <!-- LAYER 1: NavigationView shell -->
        <ui:NavigationView x:Name="RootNavigation"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="True"
                           OpenPaneLength="240"
                           ScrollViewer.VerticalScrollBarVisibility="Disabled"
                           ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <!-- ─── Title Bar ─── -->
            <ui:NavigationView.Header>
                <ui:TitleBar Title="PocketMC Desktop"
                             ShowMaximize="True"
                             ShowMinimize="True"
                             ShowClose="True">
                    <ui:TitleBar.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Breadcrumb trail -->
                            <StackPanel x:Name="BreadcrumbHost"
                                        Grid.Column="0" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="8,0,16,0">
                                <TextBlock x:Name="BreadcrumbRoot"
                                           Text="PocketMC"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="BreadcrumbSeparator"
                                           Text="  ›  "
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                <TextBlock x:Name="BreadcrumbCurrent"
                                           Text=""
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </StackPanel>

                            <!-- Context for detail pages like Console -->
                            <Border x:Name="TitleBarContextBorder"
                                    Grid.Column="1"
                                    Background="#12FFFFFF"
                                    CornerRadius="4"
                                    Padding="10,3"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TitleBarContextTitle"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TitleBarContextSeparator"
                                               Text="  •  "
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                    <TextBlock x:Name="TitleBarContextStatus"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- Global resource health pill -->
                            <Border x:Name="GlobalHealthBorder"
                                    Grid.Column="2"
                                    Background="#18FFFFFF"
                                    CornerRadius="4"
                                    Padding="10,3"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="GlobalHealthTextBlock"
                                           Text=""
                                           FontSize="11"
                                           Foreground="Silver"/>
                            </Border>
                        </Grid>
                    </ui:TitleBar.Header>
                </ui:TitleBar>
            </ui:NavigationView.Header>

            <!-- ─── Sidebar Items ─── -->
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem x:Name="NavDashboard"
                                       Content="Dashboard"
                                       Icon="{ui:SymbolIcon Home24}"
                                       TargetPageType="{x:Type views:DashboardPage}"/>
                <ui:NavigationViewItem x:Name="NavTunnel"
                                       Content="Tunnel"
                                       Icon="{ui:SymbolIcon Globe24}"
                                       TargetPageType="{x:Type views:TunnelPage}"/>
                <ui:NavigationViewItem x:Name="NavJavaSetup"
                                       Content="Java Setup"
                                       Icon="{ui:SymbolIcon ArrowDownload24}"
                                       TargetPageType="{x:Type views:JavaSetupPage}"/>
            </ui:NavigationView.MenuItems>

            <!-- ─── Footer ─── -->
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem x:Name="NavSettings"
                                       Content="Settings"
                                       Icon="{ui:SymbolIcon Settings24}"
                                       TargetPageType="{x:Type views:AppSettingsPage}"/>
                <ui:NavigationViewItem x:Name="NavAbout"
                                       Content="About"
                                       Icon="{ui:SymbolIcon Info24}"
                                       TargetPageType="{x:Type views:AboutPage}"/>
            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
