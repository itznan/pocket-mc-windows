<Page x:Class="PocketMC.Desktop.Views.PlayitGuidePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Playit.gg Setup Guide">

    <Grid Margin="28,20,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <ui:Button Content="Back"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon ArrowLeft24}"
                           MinWidth="88"
                           Margin="0,0,14,0"
                           Click="BtnBack_Click"/>

                <ui:TextBlock FontTypography="Title"
                              Text="🌐 Playit.gg Agent Setup"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <ui:Card Grid.Row="1" Padding="24" MaxWidth="600" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="A browser window has opened. Follow these steps:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="14"
                           Margin="0,0,0,16" TextWrapping="Wrap"/>

                <StackPanel Margin="12,0,0,0">
                    <TextBlock FontSize="14" Margin="0,6">
                        <Run FontWeight="SemiBold" Text="1. " Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Run Text="Log in to your Playit.gg account." Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </TextBlock>

                    <TextBlock FontSize="14" Margin="0,6">
                        <Run FontWeight="SemiBold" Text="2. " Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Run Text="Enter a name for this agent (e.g., 'My PC')." Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </TextBlock>

                    <TextBlock FontSize="14" Margin="0,6">
                        <Run FontWeight="SemiBold" Text="3. " Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Run Text="Click 'Create Agent'." Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>

                <TextBlock Foreground="#89B4FA" FontSize="13" Margin="0,20,0,0"
                           FontStyle="Italic" TextWrapping="Wrap"
                           Text="This page will close automatically when setup is complete. You can also go back manually if needed."/>

                <StackPanel Orientation="Horizontal" Margin="0,24,0,0" HorizontalAlignment="Right">
                    <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText"
                               Text="Waiting for setup..."
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </ui:Card>
    </Grid>
</Page>
