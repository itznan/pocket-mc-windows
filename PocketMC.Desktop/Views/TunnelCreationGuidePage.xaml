<Page x:Class="PocketMC.Desktop.Views.TunnelCreationGuidePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Create Tunnel">

    <Grid Margin="28,20,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <ui:Button Content="Back"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon ArrowLeft24}"
                           MinWidth="88"
                           Margin="0,0,14,0"
                           Click="BtnBack_Click"/>

                <ui:TextBlock FontTypography="Title"
                              Text="🔗 Create a Tunnel"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <ui:Card Grid.Row="1" Padding="24" MaxWidth="600" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="A browser window has opened. Follow these steps:"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="14"
                           Margin="0,0,0,16" TextWrapping="Wrap"/>

                <StackPanel Margin="12,0,0,0">
                    <TextBlock FontSize="14" Margin="0,6">
                        <Run FontWeight="SemiBold" Text="1. " Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Run Text="Enter a tunnel name." Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </TextBlock>

                    <TextBlock FontSize="14" Margin="0,6">
                        <Run FontWeight="SemiBold" Text="2. " Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Run Text="Select tunnel type: Minecraft Java." Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </TextBlock>

                    <TextBlock FontSize="14" Margin="0,6">
                        <Run FontWeight="SemiBold" Text="3. " Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Run Text="Select 'Free Network'." Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </TextBlock>

                    <TextBlock FontSize="14" Margin="0,6" x:Name="PortInstructionText">
                        <Run FontWeight="SemiBold" Text="4. " Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Run Text="Enter port: " Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <Run FontWeight="Bold" Foreground="#F9E2AF" x:Name="PortValueRun" Text="25565"/>
                        <Run Text=" (your server's configured port)." Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </TextBlock>

                    <TextBlock FontSize="14" Margin="0,6">
                        <Run FontWeight="SemiBold" Text="5. " Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Run Text="Click 'Create'." Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>

                <TextBlock Foreground="#89B4FA" FontSize="13" Margin="0,20,0,0"
                           FontStyle="Italic" TextWrapping="Wrap"
                           Text="This page will close automatically when the tunnel is detected."/>

                <StackPanel Orientation="Horizontal" Margin="0,24,0,0" HorizontalAlignment="Right">
                    <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText"
                               Text="Polling for new tunnel..."
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </ui:Card>
    </Grid>
</Page>
