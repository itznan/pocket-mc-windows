<Page x:Class="PocketMC.Desktop.Features.Setup.AppSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="{DynamicResource AppSettingsTitle}">

    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource AppSettingsTitle}"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                   Margin="24,24,24,16" />

        <ScrollViewer Grid.Row="1"
                      x:Name="MainScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,0,24,24">
            <StackPanel>
                <!-- UPDATES -->
                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon ArrowDownload24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsCardSoftwareUpdates}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource SettingsCardSoftwareUpdatesDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <TextBlock Text="{DynamicResource CheckForUpdatesButton}" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Text="{DynamicResource SettingsCardSoftwareUpdatesDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,12" TextWrapping="Wrap"/>
                        <ui:Button x:Name="BtnCheckUpdates" Content="{DynamicResource CheckForUpdatesButton}" Icon="{ui:SymbolIcon ArrowSync24}" Appearance="Secondary" Click="CheckUpdates_Click"/>
                        <TextBlock x:Name="UpdateStatusText" FontSize="12" Margin="0,8,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Color24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsCardAppearance}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource SettingsCardAppearanceDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <!-- Theme Selection -->
                        <TextBlock Text="{DynamicResource ApplicationThemeLabel}" FontSize="14" FontWeight="Medium" Margin="0,0,0,0"/>
                        <TextBlock Text="{DynamicResource ApplicationThemeDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"/>
                        <ComboBox x:Name="ThemeCombo" Width="260" HorizontalAlignment="Left" SelectionChanged="ThemeCombo_SelectionChanged">
                            <ComboBoxItem Content="System Default" Tag="System"/>
                            <ComboBoxItem Content="Light" Tag="Light"/>
                            <ComboBoxItem Content="Dark" Tag="Dark"/>
                        </ComboBox>

                        <Separator Margin="0,16" Opacity="0.15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource TransparentMicaEffectLabel}" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="{DynamicResource TransparentMicaEffectDescription}"
                                           TextWrapping="Wrap" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                           FontSize="12" 
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleMica" 
                                             Grid.Column="1" 
                                             VerticalAlignment="Center" 
                                             Checked="ToggleMica_Checked" 
                                             Unchecked="ToggleMica_Unchecked" />
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Globe24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsCardLanguage}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource SettingsCardLanguageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>
                    <StackPanel Margin="16,8,16,16">
                        <TextBlock Text="{DynamicResource ApplicationLanguageLabel}" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Text="{DynamicResource ApplicationLanguageDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"/>
                        <ComboBox x:Name="LanguageCombo" Width="260" HorizontalAlignment="Left" SelectionChanged="LanguageCombo_SelectionChanged">
                            <ComboBoxItem Content="{DynamicResource LanguageEnglish}" Tag="en-US"/>
                            <ComboBoxItem Content="{DynamicResource LanguageSpanish}" Tag="es-ES"/>
                            <ComboBoxItem Content="{DynamicResource LanguageHindi}" Tag="hi-IN"/>
                            <ComboBoxItem Content="{DynamicResource LanguageFrench}" Tag="fr-FR"/>
                            <ComboBoxItem Content="{DynamicResource LanguageGerman}" Tag="de-DE"/>
                            <ComboBoxItem Content="{DynamicResource LanguageJapanese}" Tag="ja-JP"/>
                        </ComboBox>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Key24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsCardApiConfiguration}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource SettingsCardApiConfigurationDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="{DynamicResource CurseForgeApiKeyLabel}" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="{DynamicResource CurseForgeApiKeyDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <ui:TextBox x:Name="CurseForgeKeyInput" Margin="0,8,0,0" PlaceholderText="$2a$10$..."/>
                            </StackPanel>
                            <ui:Button Grid.Column="1" Content="{DynamicResource SaveKeyButton}" Appearance="Primary" VerticalAlignment="Bottom" Click="SaveApiKey_Click"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon BrainCircuit24}" Margin="0,0,0,12">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsCardAiSummarization}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource SettingsCardAiSummarizationDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <!-- Provider Selection -->
                        <TextBlock Text="{DynamicResource AiProviderLabel}" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Text="{DynamicResource AiProviderDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"/>
                        <ComboBox x:Name="AiProviderCombo" Width="260" HorizontalAlignment="Left" SelectionChanged="AiProviderCombo_SelectionChanged">
                            <ComboBoxItem Content="Google Gemini" IsSelected="True"/>
                            <ComboBoxItem Content="OpenAI"/>
                            <ComboBoxItem Content="Anthropic Claude"/>
                            <ComboBoxItem Content="Mistral AI"/>
                            <ComboBoxItem Content="Groq"/>
                        </ComboBox>

                        <Separator Margin="0,16" Opacity="0.15"/>

                        <!-- API Key Input -->
                        <TextBlock Text="{DynamicResource ApiKeyLabel}" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Text="{DynamicResource ApiKeyDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="AiApiKeyInput" PlaceholderText="Paste your API key here..." Margin="0,0,8,0"/>
                            <ui:Button Grid.Column="1" Content="{DynamicResource ValidateButton}" Appearance="Secondary" Click="ValidateAiKey_Click" Margin="0,0,8,0" ToolTip="Test the key with a small API call"/>
                            <ui:Button Grid.Column="2" Content="{DynamicResource SaveButton}" Appearance="Primary" Click="SaveAiKey_Click"/>
                        </Grid>
                        <TextBlock x:Name="AiKeyStatus" Text="" FontSize="12" Margin="0,6,0,0" Foreground="#A6E3A1"/>

                        <Separator Margin="0,16" Opacity="0.15"/>

                        <!-- Toggles -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource EnableAiSummarizationLabel}" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="{DynamicResource EnableAiSummarizationDescription}"
                                           TextWrapping="Wrap" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                           FontSize="12" 
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleAiSummarization" Grid.Column="1" VerticalAlignment="Center" 
                                             Checked="ToggleAiSummarization_Changed" 
                                             Unchecked="ToggleAiSummarization_Changed"/>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource AutomaticSummarizationLabel}" FontSize="14" FontWeight="Medium"/>
                                <TextBlock Text="{DynamicResource AutomaticSummarizationDescription}"
                                           TextWrapping="Wrap" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                           FontSize="12" 
                                           Margin="0,4,24,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="ToggleAutoSummarize" Grid.Column="1" VerticalAlignment="Center" 
                                             Checked="ToggleAutoSummarize_Changed" 
                                             Unchecked="ToggleAutoSummarize_Changed"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander>

                <ui:CardExpander IsExpanded="False" Icon="{ui:SymbolIcon Stethoscope24}">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SettingsCardDiagnostics}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource SettingsCardDiagnosticsDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>

                    <StackPanel Margin="16,8,16,16">
                        <!-- Dependency Health -->
                        <TextBlock Text="External Services Availability" FontSize="14" FontWeight="Medium" Margin="0,0,0,4"/>
                        <ItemsControl x:Name="DependencyHealthList" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{Binding ColorBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Details}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,4,0,12" Opacity="0.15"/>

                        <!-- Disaster Recovery -->
                        <TextBlock Text="{DynamicResource DisasterRecoveryLabel}" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Text="{DynamicResource DisasterRecoveryDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,12" TextWrapping="Wrap"/>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <ui:TextBox x:Name="ExternalBackupPathInput" PlaceholderText="Select an external path..." IsReadOnly="True" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ui:Button Grid.Column="1" Content="{DynamicResource BrowseButton}" Click="BrowseExternalBackup_Click" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ui:Button Grid.Column="2" Content="{DynamicResource SaveExternalBackupButton}" Appearance="Primary" Click="SaveExternalBackup_Click" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Margin="0,4,0,12" Opacity="0.15"/>

                        <TextBlock Text="Export Support Bundle" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Text="Generates a ZIP archive containing redacted App logs, system information, and running server metrics. Attach this to GitHub issues or Discord help requests." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,12" TextWrapping="Wrap"/>
                        <ui:Button x:Name="BtnExportBundle" Content="Generate Support Bundle" Icon="{ui:SymbolIcon Archive24}" Appearance="Secondary" Click="ExportBundle_Click"/>
                        <TextBlock x:Name="ExportBundleStatusText" FontSize="12" Margin="0,8,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </ui:CardExpander>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
