<Page x:Class="PocketMC.Desktop.Features.Tunnel.TunnelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="{DynamicResource TunnelPageTitle}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="36,24,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <ui:TextBlock FontTypography="Title" Text="{DynamicResource TunnelPageTitle}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="{DynamicResource TunnelPageDescription}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       FontSize="13"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left column: Agent status content -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource TunnelAgentStatusLabel}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtStatusValue"
                                   Text="{DynamicResource TunnelStatusChecking}"
                                   Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                   FontSize="26"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtStatusDetail"
                                   Text="{DynamicResource TunnelPreparingDiagnostics}"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TunnelAgentPathLabel}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="12"
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="TxtExecutablePath"
                                       Text=""
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="0,0,0,12">
                        <ProgressBar x:Name="DownloadProgressBar"
                                     Height="6"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"
                                     Visibility="Collapsed"/>
                        <TextBlock x:Name="TxtDownloadProgress"
                                   Text=""
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal">
                        <ui:Button x:Name="BtnDownloadAgent"
                                   Content="{DynamicResource TunnelDownloadAgentButton}"
                                   Icon="{ui:SymbolIcon ArrowDownload24}"
                                   Appearance="Primary"
                                   Click="BtnDownloadAgent_Click"
                                   Cursor="Hand"
                                   Margin="0,0,8,0"/>
                        <ui:Button x:Name="BtnSetupAgent"
                                   Content="{DynamicResource TunnelSetupAgentButton}"
                                   Icon="{ui:SymbolIcon PersonAdd24}"
                                   Appearance="Secondary"
                                   Click="BtnSetupAgent_Click"
                                   Cursor="Hand"
                                   Margin="0,0,8,0"/>
                        <ui:Button x:Name="BtnConnect"
                                   Content="{DynamicResource TunnelConnectButton}"
                                   Icon="{ui:SymbolIcon Play24}"
                                   Appearance="Secondary"
                                   Click="BtnConnect_Click"
                                   Cursor="Hand"
                                   Margin="0,0,8,0"/>
                        <ui:Button x:Name="BtnDisconnect"
                                   Content="{DynamicResource TunnelDisconnectButton}"
                                   Icon="{ui:SymbolIcon Stop24}"
                                   Appearance="Secondary"
                                   Click="BtnDisconnect_Click"
                                   Cursor="Hand"
                                   Margin="0,0,8,0"/>
                        <ui:Button x:Name="BtnRefresh"
                                   Content="{DynamicResource TunnelRefreshButton}"
                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                   Appearance="Secondary"
                                   Click="BtnRefresh_Click"
                                   Cursor="Hand"/>
                    </StackPanel>
                </Grid>

                <!-- Right column: PlayIt.gg attribution -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Margin="20,0,0,0">
                    <TextBlock Text="{DynamicResource TunnelSpecialThanks}"
                               FontSize="13"
                               FontWeight="Medium"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,6">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#89dceb" Offset="0.0" />
                                <GradientStop Color="#89b4fa" Offset="1.0" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <ui:Button Content="{DynamicResource TunnelVisitPlayitButton}"
                               Icon="{ui:SymbolIcon Open24}"
                               Appearance="Secondary"
                               FontSize="11"
                               Padding="10,5"
                               HorizontalAlignment="Right"
                               Click="BtnVisitPlayit_Click"
                               Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Active Tunnels Section -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ui:TextBlock Grid.Row="0"
                              FontTypography="Subtitle"
                              Text="{DynamicResource TunnelActiveTunnelsLabel}"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              Margin="0,0,0,6"/>
                <TextBlock x:Name="TxtTunnelListStatus"
                           Grid.Row="1"
                           Text="{DynamicResource TunnelNoDataYetMessage}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,12"
                           TextWrapping="Wrap"/>

                <!-- Tunnel cards with management controls -->
                <ItemsControl x:Name="TunnelList"
                              Grid.Row="2"
                              Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <!-- Row 1: Name (editable) + Save + Enable toggle + Delete + Copy -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ui:SymbolIcon Grid.Column="0"
                                                       Symbol="Globe24"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                                       VerticalAlignment="Center"/>

                                        <!-- Inline editable name -->
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding Name, Mode=OneWay}"
                                                 Tag="{Binding Id}"
                                                 FontSize="14"
                                                 FontWeight="SemiBold"
                                                 Background="Transparent"
                                                 BorderThickness="0,0,0,1"
                                                 BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                 VerticalAlignment="Center"
                                                 Padding="4,4"
                                                 TextChanged="TunnelName_TextChanged"
                                                 KeyDown="TunnelName_KeyDown"
                                                 ToolTip="{DynamicResource TunnelEditNameToolTip}"/>

                                        <!-- Save name button -->
                                        <ui:Button Grid.Column="4"
                                                   Content="{DynamicResource TunnelSaveButton}"
                                                   Appearance="Primary"
                                                   FontSize="11"
                                                   Padding="10,4"
                                                   IsEnabled="False"
                                                   Click="BtnSaveName_Click"
                                                   Tag="{Binding Id}"
                                                   Cursor="Hand"
                                                   VerticalAlignment="Center"
                                                   ToolTip="{DynamicResource TunnelSaveNameToolTip}"/>

                                        <!-- Enable/disable toggle (native ToggleSwitch) -->
                                        <ui:ToggleSwitch Grid.Column="6"
                                                         IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                         Tag="{Binding Id}"
                                                         Checked="ToggleEnabled_Changed"
                                                         Unchecked="ToggleEnabled_Changed"
                                                         ToolTip="{DynamicResource TunnelEnableDisableToolTip}"
                                                         VerticalAlignment="Center"/>

                                        <!-- Delete button -->
                                        <ui:Button Grid.Column="8"
                                                   ToolTip="{DynamicResource TunnelDeleteTunnelToolTip}"
                                                   Icon="{ui:SymbolIcon Delete24}"
                                                   Appearance="Secondary"
                                                   Padding="6"
                                                   Click="BtnDeleteTunnel_Click"
                                                   Tag="{Binding Id}"
                                                   Cursor="Hand"
                                                   VerticalAlignment="Center"/>

                                        <!-- Copy address -->
                                        <ui:Button Grid.Column="10"
                                                   ToolTip="{DynamicResource TunnelCopyAddressToolTip}"
                                                   Appearance="Secondary"
                                                   Icon="{ui:SymbolIcon Copy24}"
                                                   Padding="6"
                                                   Click="BtnCopyAddress_Click"
                                                   Tag="{Binding PublicAddress}"
                                                   Cursor="Hand"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Row 2: Port (editable + Save) + Tunnel Type label + Public Address -->
                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Local Port (editable) -->
                                        <Border Grid.Column="0"
                                                Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                                                BorderBrush="{DynamicResource SystemFillColorSuccessBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="6,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{DynamicResource TunnelPortLabel}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                                           FontWeight="Medium"
                                                           Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBox Text="{Binding Port, Mode=OneWay}"
                                                         Tag="{Binding Id}"
                                                         FontSize="13"
                                                         FontWeight="Bold"
                                                         Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         MinWidth="44"
                                                         MaxWidth="80"
                                                         Padding="2,2"
                                                         VerticalAlignment="Center"
                                                         TextChanged="TunnelPort_TextChanged"
                                                         KeyDown="TunnelPort_KeyDown"
                                                         IsEnabled="{Binding HasAgentOrigin}"
                                                         ToolTip="{DynamicResource TunnelEditPortToolTip}"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Save port button -->
                                        <ui:Button Grid.Column="2"
                                                   Content="{DynamicResource TunnelSaveButton}"
                                                   Appearance="Primary"
                                                   FontSize="11"
                                                   Padding="10,4"
                                                   IsEnabled="False"
                                                   Click="BtnSavePort_Click"
                                                   Tag="{Binding Id}"
                                                   Cursor="Hand"
                                                   VerticalAlignment="Center"
                                                   ToolTip="{DynamicResource TunnelSavePortToolTip}"/>

                                        <!-- Tunnel Type (read-only) -->
                                        <Border Grid.Column="4"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                BorderThickness="0"
                                                CornerRadius="6"
                                                Padding="10,5"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TunnelType}"
                                                       FontSize="12"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Public Address -->
                                        <Border Grid.Column="6"
                                                Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}"
                                                BorderBrush="{DynamicResource SystemFillColorAttentionBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,5"
                                                Visibility="{Binding HasPublicAddress, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Link24"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                                               Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding PublicAddress}"
                                                           FontSize="13"
                                                           FontWeight="Medium"
                                                           Foreground="{DynamicResource SystemFillColorAttentionBrush}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Row 3: Inline error message (hidden by default) -->
                                    <TextBlock x:Name="TxtTunnelError"
                                               Tag="{Binding Id}"
                                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                               FontSize="12"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</Page>
