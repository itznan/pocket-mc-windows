<Page x:Class="PocketMC.Desktop.Views.ServerConsolePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Server Console">
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Top bar: Server name, status, and controls -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <ui:Button Grid.Column="0" Content="Back" Appearance="Secondary" 
                       Icon="{ui:SymbolIcon ArrowLeft24}" Click="BtnBack_Click" Cursor="Hand" Margin="0,0,12,0"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:TextBlock FontTypography="Subtitle" Text="{Binding ServerName}" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" 
                           FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
            
            <ui:Button Grid.Column="2" Content="Stop Server" Appearance="Danger"
                       Icon="{ui:SymbolIcon Stop24}" Click="BtnStop_Click" Cursor="Hand" Margin="0,0,4,0"/>
            <ui:Button Grid.Column="3" Content="Restart" Appearance="Secondary"
                       Icon="{ui:SymbolIcon ArrowSync24}" Click="BtnRestart_Click" Cursor="Hand"/>
        </Grid>
        
        <!-- Console output area -->
        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="8" Padding="8">
            <Grid>
                <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="LogView" ItemsSource="{Binding Logs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel VirtualizationMode="Recycling"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" Foreground="{Binding TextColor}" 
                                           FontFamily="Consolas" FontSize="13" TextWrapping="Wrap"
                                           Padding="4,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <Border x:Name="CrashBanner" VerticalAlignment="Top" Background="#33FF0000" BorderBrush="#88FF0000" BorderThickness="1" CornerRadius="4" Padding="12" Margin="10" Visibility="Collapsed">
                    <TextBlock x:Name="TxtCrashLog" Foreground="#FF6B6B" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>
        
        <!-- Command input bar -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <ui:TextBox x:Name="TxtCommand" Grid.Column="0" PlaceholderText="Type a command..." 
                        Margin="0,0,8,0" KeyDown="TxtCommand_KeyDown"/>
            <ui:Button Grid.Column="1" Content="Send" Appearance="Primary"
                       Icon="{ui:SymbolIcon Send24}" Click="BtnSend_Click" Cursor="Hand"/>
        </Grid>
    </Grid>
</Page>
