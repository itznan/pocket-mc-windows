<Page x:Class="PocketMC.Desktop.Features.Setup.RootDirectorySetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Setup">

    <Grid Margin="36,28,36,28">
        <Border MaxWidth="660"
                Padding="32"
                CornerRadius="20"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="{DynamicResource RootDirectorySetupAppTitle}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,16"/>

                <ui:TextBlock FontTypography="Title"
                              Text="{DynamicResource RootDirectorySetupHeading}"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              Margin="0,0,0,10"/>

                <TextBlock Text="{DynamicResource RootDirectorySetupDescription}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           FontSize="14"
                           Margin="0,0,0,24"/>

                <TextBlock Text="{DynamicResource RootDirectoryFolderNameLabel}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="TxtSuggestedFolderName"
                         IsReadOnly="True"
                         Text="PocketMC"
                         Padding="14,10"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Background="#12000000"
                         BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                         BorderThickness="1"
                         Margin="0,0,0,18"/>

                <TextBlock Text="{DynamicResource RootDirectoryPreviewLabel}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"
                           Margin="0,0,0,8"/>
                <TextBox x:Name="TxtSuggestedPath"
                         IsReadOnly="True"
                         Padding="14,10"
                         FontFamily="Consolas"
                         TextWrapping="Wrap"
                         Background="#12000000"
                         BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                         BorderThickness="1"
                         Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal">
                    <ui:Button x:Name="SelectDirectoryButton"
                               Content="{DynamicResource SelectDirectoryButton}"
                               Icon="{ui:SymbolIcon Folder24}"
                               Appearance="Primary"
                               MinWidth="164"
                               HorizontalAlignment="Left"
                               Click="BtnSelectDirectory_Click"
                               Cursor="Hand"/>

                    <ui:Button x:Name="ContinueButton"
                               Content="{DynamicResource ContinueButton}"
                               Appearance="Secondary"
                               MinWidth="128"
                               Margin="12,0,0,0"
                               Click="BtnContinue_Click"
                               Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
