<ui:FluentWindow x:Class="PocketMC.Desktop.Features.Tunnel.CreateTunnelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Create Tunnel"
        Width="520" Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowCornerPreference="Round" ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica" Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource CreateTunnelTitle}"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#89B4FA"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{DynamicResource CreateTunnelDescription}"
                       Foreground="#BAC2DE" FontSize="13"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Form Fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel>
                <!-- Tunnel Name -->
                <TextBlock Text="{DynamicResource TunnelNameLabel}"
                           Foreground="#CDD6F4" FontWeight="SemiBold" FontSize="13"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="TxtTunnelName"
                         MaxLength="64"
                         FontSize="13"
                         Foreground="#CDD6F4"
                         Background="#313244"
                         BorderBrush="#45475A"
                         CaretBrush="#CDD6F4"
                         Padding="10,8"
                         ToolTip="{DynamicResource TunnelNameTooltip}"/>
                <TextBlock x:Name="TxtNameError"
                           Foreground="#F38BA8" FontSize="11"
                           Margin="0,4,0,0"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <!-- Tunnel Type -->
                <TextBlock Text="{DynamicResource TunnelTypeLabel}"
                           Foreground="#CDD6F4" FontWeight="SemiBold" FontSize="13"
                           Margin="0,16,0,6"/>
                <ComboBox x:Name="CmbTunnelType"
                          FontSize="13"
                          Foreground="#CDD6F4"
                          Background="#313244"
                          BorderBrush="#45475A"
                          SelectedIndex="0"
                          MinHeight="36">
                    <ComboBoxItem Content="{DynamicResource TunnelTypeMinecraftJava}" Tag="minecraft-java"/>
                    <ComboBoxItem Content="{DynamicResource TunnelTypeMinecraftBedrock}" Tag="minecraft-bedrock"/>
                </ComboBox>

                <!-- Local Port -->
                <TextBlock Text="{DynamicResource LocalPortLabel}"
                           Foreground="#CDD6F4" FontWeight="SemiBold" FontSize="13"
                           Margin="0,16,0,6"/>
                <TextBox x:Name="TxtLocalPort"
                         Text="25565"
                         MaxLength="5"
                         FontSize="13"
                         Foreground="#CDD6F4"
                         Background="#313244"
                         BorderBrush="#45475A"
                         CaretBrush="#CDD6F4"
                         Padding="10,8"
                         ToolTip="{DynamicResource LocalPortTooltip}"
                         PreviewTextInput="TxtLocalPort_PreviewTextInput"/>
                <TextBlock x:Name="TxtPortError"
                           Foreground="#F38BA8" FontSize="11"
                           Margin="0,4,0,0"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <!-- Region -->
                <TextBlock Text="{DynamicResource RegionLabel}"
                           Foreground="#CDD6F4" FontWeight="SemiBold" FontSize="13"
                           Margin="0,16,0,6"/>
                <ComboBox x:Name="CmbRegion"
                          FontSize="13"
                          Foreground="#CDD6F4"
                          Background="#313244"
                          BorderBrush="#45475A"
                          SelectedIndex="0"
                          MinHeight="36">
                    <ComboBoxItem Content="{DynamicResource TunnelRegionGlobal}" Tag="global"/>
                    <ComboBoxItem Content="{DynamicResource TunnelRegionNorthAmerica}" Tag="north-america"/>
                    <ComboBoxItem Content="{DynamicResource TunnelRegionEurope}" Tag="europe"/>
                    <ComboBoxItem Content="{DynamicResource TunnelRegionAsia}" Tag="asia"/>
                    <ComboBoxItem Content="{DynamicResource TunnelRegionIndia}" Tag="india"/>
                    <ComboBoxItem Content="{DynamicResource TunnelRegionSouthAmerica}" Tag="south-america"/>
                    <ComboBoxItem Content="{DynamicResource TunnelRegionJapan}" Tag="japan"/>
                    <ComboBoxItem Content="{DynamicResource TunnelRegionAustralia}" Tag="australia"/>
                </ComboBox>

                <!-- Enable immediately -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource EnableImmediatelyLabel}"
                                   Foreground="#CDD6F4" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="{DynamicResource EnableImmediatelyDescription}"
                                   Foreground="#A6ADC8" FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <ui:ToggleSwitch x:Name="ToggleEnabled"
                                     Grid.Column="1"
                                     IsChecked="True"
                                     VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Inline error message area -->
        <Border Grid.Row="2"
                x:Name="ErrorBorder"
                Background="#3B1A26"
                BorderBrush="#F38BA8"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <TextBlock x:Name="TxtApiError"
                       Foreground="#F38BA8" FontSize="12"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Action Buttons -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Spinner (hidden by default) -->
            <ui:ProgressRing x:Name="SpinnerRing"
                             Grid.Column="0"
                             Width="20" Height="20"
                             IsIndeterminate="True"
                             Visibility="Collapsed"
                             Margin="0,0,12,0"
                             VerticalAlignment="Center"/>

            <ui:Button Grid.Column="2"
                       x:Name="BtnCancel"
                       Content="{DynamicResource CancelButton}"
                       Width="100"
                       Click="BtnCancel_Click"/>

            <ui:Button Grid.Column="4"
                       x:Name="BtnCreate"
                       Content="{DynamicResource CreateButton}"
                       Appearance="Primary"
                       Width="120"
                       Click="BtnCreate_Click"/>
        </Grid>
    </Grid>
</ui:FluentWindow>
