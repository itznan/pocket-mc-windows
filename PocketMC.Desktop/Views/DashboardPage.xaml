<Page x:Class="PocketMC.Desktop.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Dashboard">
    
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Inverse bool converter -->
        <Style x:Key="HiddenWhenRunning" TargetType="FrameworkElement">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowRunningControls}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="VisibleWhenRunning" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowRunningControls}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
            <ui:TextBlock FontTypography="Title" Text="Instances" Margin="0,0,16,0" VerticalAlignment="Center"/>
            <ui:Button Content="New Instance" Icon="{ui:SymbolIcon Add24}" Appearance="Primary" Click="BtnNewInstance_Click" Cursor="Hand"/>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="InstanceGrid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Outer Border for green glow — ui:Card ignores BorderBrush overrides -->
                        <Border Margin="0,0,16,16" CornerRadius="8" Padding="0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="BorderBrush" Value="#4CAF50"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ui:Card Width="280" Cursor="Hand">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Title row -->
                                <Grid Grid.Row="0" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <ui:TextBlock Grid.Column="0" FontTypography="Subtitle" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    
                                    <ui:Button Grid.Column="1" Appearance="Transparent" Icon="{ui:SymbolIcon MoreVertical24}" 
                                               Click="BtnMoreOptions_Click" Cursor="Hand" Padding="6,4" Margin="0,-6,-6,0" VerticalAlignment="Top">
                                        <ui:Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Rename" Click="RenameInstance_Click" />
                                                <MenuItem Header="Delete" Click="DeleteInstance_Click" />
                                            </ContextMenu>
                                        </ui:Button.ContextMenu>
                                    </ui:Button>
                                </Grid>
                                
                                <!-- Status badge -->
                                <TextBlock Grid.Row="1" Text="{Binding StatusText}" 
                                           Foreground="{Binding StatusColor}" FontSize="11" FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                
                                <ui:TextBlock Grid.Row="2" FontTypography="Caption" Text="{Binding Description}" 
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                              TextWrapping="Wrap" Margin="0,0,0,12"/>
                                
                                <!-- Running metrics panel -->
                                <Grid Grid.Row="2" Style="{StaticResource VisibleWhenRunning}" Margin="0,4,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                        <TextBlock Text="{Binding CpuText}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                        <TextBlock Text="{Binding RamText}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    
                                    <!-- Player count -->
                                    <TextBlock Text="{Binding PlayerStatus}" FontSize="11" FontWeight="Medium" 
                                               Foreground="{Binding StatusColor}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,-22,0,0" />
                                </Grid>

                                <!-- Action buttons: STOPPED state -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                                            Style="{StaticResource HiddenWhenRunning}">
                                    <ui:Button Content="Start" Appearance="Primary" Margin="0,0,4,0"
                                               Icon="{ui:SymbolIcon Play24}" Click="BtnStart_Click" Cursor="Hand"/>
                                    <ui:Button Content="Settings" Appearance="Secondary" Margin="0,0,4,0"
                                               Icon="{ui:SymbolIcon Settings24}" Click="BtnManage_Click" Cursor="Hand"/>
                                    <ui:Button Icon="{ui:SymbolIcon Folder24}" Click="BtnOpenFolder_Click" Cursor="Hand"/>
                                </StackPanel>
                                
                                <!-- Action buttons: RUNNING state -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                                            Style="{StaticResource VisibleWhenRunning}">
                                    <ui:Button Content="Console" Appearance="Primary" Margin="0,0,4,0"
                                               Icon="{ui:SymbolIcon WindowConsole20}" Click="BtnConsole_Click" Cursor="Hand"/>
                                    <ui:Button Content="Settings" Appearance="Secondary" Margin="0,0,4,0"
                                               Icon="{ui:SymbolIcon Settings24}" Click="BtnManage_Click" Cursor="Hand"/>
                                    <ui:Button Content="{Binding StopButtonText}" Appearance="Danger" 
                                               Icon="{ui:SymbolIcon Stop24}" Click="BtnStop_Click" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </ui:Card>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
