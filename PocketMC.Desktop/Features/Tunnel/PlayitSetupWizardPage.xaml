<Page x:Class="PocketMC.Desktop.Features.Tunnel.PlayitSetupWizardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Connect Playit Agent">

    <Grid Margin="28,20,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <ui:Button Content="{DynamicResource BackButton}"
                           Appearance="Secondary"
                           Icon="{ui:SymbolIcon ArrowLeft24}"
                           MinWidth="88"
                           Margin="0,0,14,0"
                           Click="BtnBack_Click"/>

                <ui:TextBlock FontTypography="Title"
                              Text="{DynamicResource PlayitSetupWizardTitle}"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Wizard Content -->
        <ui:Card Grid.Row="1" Padding="28" MaxWidth="640" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Step Indicator -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <Border x:Name="StepDot1" Width="32" Height="32" CornerRadius="16"
                            Background="#89B4FA" Margin="0,0,6,0">
                        <TextBlock Text="1" Foreground="White" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Width="28" Height="2" Background="#30FFFFFF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Border x:Name="StepDot2" Width="32" Height="32" CornerRadius="16"
                            Background="#30FFFFFF" Margin="0,0,6,0">
                        <TextBlock Text="2" Foreground="#80FFFFFF" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Width="28" Height="2" Background="#30FFFFFF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Border x:Name="StepDot3" Width="32" Height="32" CornerRadius="16"
                            Background="#30FFFFFF" Margin="0,0,6,0">
                        <TextBlock Text="3" Foreground="#80FFFFFF" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Width="28" Height="2" Background="#30FFFFFF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Border x:Name="StepDot4" Width="32" Height="32" CornerRadius="16"
                            Background="#30FFFFFF">
                        <TextBlock Text="4" Foreground="#80FFFFFF" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Step Title -->
                <TextBlock x:Name="TxtStepTitle" Grid.Row="1"
                           Text="{DynamicResource PlayitSetupStepTitle}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,16"/>

                <!-- Step Content Area -->
                <Grid Grid.Row="2" MinHeight="140">
                    <!-- Step 1: Open setup page + choose "Other" -->
                    <StackPanel x:Name="Step1Panel" Visibility="Visible">
                        <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,14"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="{DynamicResource PlayitSetupStep1Instruction}"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,16"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="{DynamicResource PlayitSetupStep1DropdownInstruction}"/>
                            <Run Text=" &quot;Other&quot;" FontWeight="Bold" Foreground="#F9E2AF"/>
                            <Run Text="."/>
                        </TextBlock>
                        <ui:Button Content="{DynamicResource OpenSetupPageButton}"
                                   Icon="{ui:SymbolIcon Globe24}"
                                   Appearance="Primary"
                                   Cursor="Hand"
                                   Click="BtnOpenSetupPage_Click"/>
                    </StackPanel>

                    <!-- Step 2: Click Next in Playit dashboard -->
                    <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                        <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,14"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="{DynamicResource PlayitSetupStep2Instruction}"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="{DynamicResource PlayitSetupStep2ClickNextPrefix}"/>
                            <Run Text=" &quot;Next&quot;" FontWeight="Bold" Foreground="#F9E2AF"/>
                            <Run Text=" {DynamicResource PlayitSetupStep2ClickNextSuffix}"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Step 3: Copy the setup code -->
                    <StackPanel x:Name="Step3Panel" Visibility="Collapsed">
                        <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,14"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="{DynamicResource PlayitSetupStep3InstructionPrefix}"/>
                            <Run Text=" setup code" FontWeight="Bold" Foreground="#F9E2AF"/>
                            <Run Text="{DynamicResource PlayitSetupStep3InstructionSuffix}"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" FontSize="13" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   FontStyle="Italic"
                                   Text="{DynamicResource PlayitSetupStep3ExampleCode}"/>
                    </StackPanel>

                    <!-- Step 4: Paste setup code and connect -->
                    <StackPanel x:Name="Step4Panel" Visibility="Collapsed">
                        <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,0,0,14"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="Paste the setup code you copied from Playit and click Connect."/>

                        <Border Background="#12FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtWizardSetupCode"
                                         Grid.Column="0"
                                         Padding="10,8"
                                         TextWrapping="NoWrap"
                                         ToolTip="Paste the Playit setup code here."
                                         VerticalAlignment="Center"/>
                                <ui:Button x:Name="BtnWizardConnect"
                                           Grid.Column="1"
                                           Content="Connect"
                                           Icon="{ui:SymbolIcon PlugConnected24}"
                                           Appearance="Primary"
                                           Cursor="Hand"
                                           Margin="8,0,0,0"
                                           Click="BtnWizardConnect_Click"/>
                            </Grid>
                        </Border>

                        <!-- Status messages -->
                        <TextBlock x:Name="TxtConnectStatus"
                                   TextWrapping="Wrap" FontSize="13"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Visibility="Collapsed"/>

                        <!-- Connecting spinner -->
                        <StackPanel x:Name="ConnectingPanel" Orientation="Horizontal"
                                    Margin="0,8,0,0" Visibility="Collapsed">
                            <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16"
                                             Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtConnectingStatus"
                                       Text="{DynamicResource PlayitConnectingStatus}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <ui:Button x:Name="BtnPrevStep"
                               Content="{DynamicResource PreviousButton}"
                               Icon="{ui:SymbolIcon ArrowLeft24}"
                               Appearance="Secondary"
                               Cursor="Hand"
                               Margin="0,0,8,0"
                               Visibility="Collapsed"
                               Click="BtnPrevStep_Click"/>
                    <ui:Button x:Name="BtnNextStep"
                               Content="{DynamicResource NextButton}"
                               Icon="{ui:SymbolIcon ArrowRight24}"
                               Appearance="Primary"
                               Cursor="Hand"
                               Click="BtnNextStep_Click"/>
                </StackPanel>
            </Grid>
        </ui:Card>
    </Grid>
</Page>
