<Page x:Class="PocketMC.Desktop.Features.Tunnel.TunnelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Tunnel">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="36,24,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <ui:TextBlock FontTypography="Title" Text="Tunnel" Foreground="White" Margin="0,0,0,4"/>
            <TextBlock Text="Manage the Playit.gg agent, download the tunnel binary, and retry connections without leaving PocketMC."
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       FontSize="13"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Agent Status"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="12"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtStatusValue"
                               Text="Checking..."
                               Foreground="#F9E2AF"
                               FontSize="26"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtStatusDetail"
                               Text="Preparing tunnel diagnostics..."
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Background="#12FFFFFF"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Agent Path"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtExecutablePath"
                                   Text=""
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                    <ProgressBar x:Name="DownloadProgressBar"
                                 Height="6"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Visibility="Collapsed"/>
                    <TextBlock x:Name="TxtDownloadProgress"
                               Text=""
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Orientation="Horizontal">
                    <ui:Button x:Name="BtnDownloadAgent"
                               Content="Download Agent"
                               Icon="{ui:SymbolIcon ArrowDownload24}"
                               Appearance="Primary"
                               Click="BtnDownloadAgent_Click"
                               Cursor="Hand"
                               Margin="0,0,8,0"/>
                    <ui:Button x:Name="BtnSetupAgent"
                               Content="Setup Agent"
                               Icon="{ui:SymbolIcon PersonAdd24}"
                               Appearance="Secondary"
                               Click="BtnSetupAgent_Click"
                               Cursor="Hand"
                               Margin="0,0,8,0"/>
                    <ui:Button x:Name="BtnConnect"
                               Content="Connect"
                               Icon="{ui:SymbolIcon Play24}"
                               Appearance="Secondary"
                               Click="BtnConnect_Click"
                               Cursor="Hand"
                               Margin="0,0,8,0"/>
                    <ui:Button x:Name="BtnDisconnect"
                               Content="Disconnect"
                               Icon="{ui:SymbolIcon Stop24}"
                               Appearance="Secondary"
                               Click="BtnDisconnect_Click"
                               Cursor="Hand"
                               Margin="0,0,8,0"/>
                    <ui:Button x:Name="BtnRefresh"
                               Content="Refresh"
                               Icon="{ui:SymbolIcon ArrowSync24}"
                               Appearance="Secondary"
                               Click="BtnRefresh_Click"
                               Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Active Tunnels Section -->
        <Border Grid.Row="2"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ui:TextBlock Grid.Row="0"
                              FontTypography="Subtitle"
                              Text="Active Tunnels"
                              Foreground="White"
                              Margin="0,0,0,6"/>
                <TextBlock x:Name="TxtTunnelListStatus"
                           Grid.Row="1"
                           Text="No tunnel data yet."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,0,0,12"
                           TextWrapping="Wrap"/>

                <!-- Tunnel cards with management controls -->
                <ItemsControl x:Name="TunnelList"
                              Grid.Row="2"
                              Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#0AFFFFFF"
                                    BorderBrush="#18FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="16,14"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <!-- Row 1: Name (editable) + Save + Enable toggle + Delete + Copy -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ui:SymbolIcon Grid.Column="0"
                                                       Symbol="Globe24"
                                                       FontSize="16"
                                                       Foreground="#89B4FA"
                                                       VerticalAlignment="Center"/>

                                        <!-- Inline editable name -->
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding Name, Mode=OneWay}"
                                                 Tag="{Binding Id}"
                                                 FontSize="14"
                                                 FontWeight="SemiBold"
                                                 Background="Transparent"
                                                 BorderThickness="0,0,0,1"
                                                 BorderBrush="#30FFFFFF"
                                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                 VerticalAlignment="Center"
                                                 Padding="4,4"
                                                 TextChanged="TunnelName_TextChanged"
                                                 KeyDown="TunnelName_KeyDown"
                                                 ToolTip="Edit the tunnel name, then click Save"/>

                                        <!-- Save name button -->
                                        <ui:Button Grid.Column="4"
                                                   Content="Save"
                                                   Appearance="Primary"
                                                   FontSize="11"
                                                   Padding="10,4"
                                                   IsEnabled="False"
                                                   Click="BtnSaveName_Click"
                                                   Tag="{Binding Id}"
                                                   Cursor="Hand"
                                                   VerticalAlignment="Center"
                                                   ToolTip="Save the new tunnel name"/>

                                        <!-- Enable/disable toggle (native ToggleSwitch) -->
                                        <ui:ToggleSwitch Grid.Column="6"
                                                         IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                         Tag="{Binding Id}"
                                                         Checked="ToggleEnabled_Changed"
                                                         Unchecked="ToggleEnabled_Changed"
                                                         ToolTip="Enable or disable this tunnel"
                                                         VerticalAlignment="Center"/>

                                        <!-- Delete button -->
                                        <ui:Button Grid.Column="8"
                                                   ToolTip="Delete this tunnel"
                                                   Icon="{ui:SymbolIcon Delete24}"
                                                   Appearance="Secondary"
                                                   Padding="6"
                                                   Click="BtnDeleteTunnel_Click"
                                                   Tag="{Binding Id}"
                                                   Cursor="Hand"
                                                   VerticalAlignment="Center"/>

                                        <!-- Copy address -->
                                        <ui:Button Grid.Column="10"
                                                   ToolTip="Copy public address"
                                                   Appearance="Secondary"
                                                   Icon="{ui:SymbolIcon Copy24}"
                                                   Padding="6"
                                                   Click="BtnCopyAddress_Click"
                                                   Tag="{Binding PublicAddress}"
                                                   Cursor="Hand"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Row 2: Port (editable + Save) + Tunnel Type label + Public Address -->
                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Local Port (editable) -->
                                        <Border Grid.Column="0"
                                                Background="#15A6E3A1"
                                                BorderBrush="#30A6E3A1"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="6,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Port"
                                                           FontSize="11"
                                                           Foreground="#A6E3A1"
                                                           FontWeight="Medium"
                                                           Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBox Text="{Binding Port, Mode=OneWay}"
                                                         Tag="{Binding Id}"
                                                         FontSize="13"
                                                         FontWeight="Bold"
                                                         Foreground="#A6E3A1"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         MinWidth="44"
                                                         MaxWidth="80"
                                                         Padding="2,2"
                                                         VerticalAlignment="Center"
                                                         TextChanged="TunnelPort_TextChanged"
                                                         KeyDown="TunnelPort_KeyDown"
                                                         IsEnabled="{Binding HasAgentOrigin}"
                                                         ToolTip="Edit local port, then click Save"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Save port button -->
                                        <ui:Button Grid.Column="2"
                                                   Content="Save"
                                                   Appearance="Primary"
                                                   FontSize="11"
                                                   Padding="10,4"
                                                   IsEnabled="False"
                                                   Click="BtnSavePort_Click"
                                                   Tag="{Binding Id}"
                                                   Cursor="Hand"
                                                   VerticalAlignment="Center"
                                                   ToolTip="Save the new local port"/>

                                        <!-- Tunnel Type (read-only) -->
                                        <Border Grid.Column="4"
                                                Background="#15CBA6F7"
                                                BorderBrush="#30CBA6F7"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,5"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TunnelType}"
                                                       FontSize="12"
                                                       FontWeight="Medium"
                                                       Foreground="#CBA6F7"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Public Address -->
                                        <Border Grid.Column="6"
                                                Background="#1589B4FA"
                                                BorderBrush="#3089B4FA"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,5"
                                                Visibility="{Binding HasPublicAddress, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Link24"
                                                               FontSize="12"
                                                               Foreground="#89B4FA"
                                                               Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding PublicAddress}"
                                                           FontSize="13"
                                                           FontWeight="Medium"
                                                           Foreground="#89B4FA"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Row 3: Inline error message (hidden by default) -->
                                    <TextBlock x:Name="TxtTunnelError"
                                               Tag="{Binding Id}"
                                               Foreground="#F38BA8"
                                               FontSize="12"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</Page>
