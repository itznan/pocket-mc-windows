<Page x:Class="PocketMC.Desktop.Features.Shell.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="{DynamicResource AboutPageTitle}">

    <Grid Margin="28,20,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <ui:TextBlock FontTypography="Title" Text="{DynamicResource AboutPageHeading}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtVersion" Text="{DynamicResource AboutPageVersionLabel}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <ui:Card Padding="24" MaxWidth="600" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{DynamicResource AboutAppName}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource AboutAppDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <TextBlock Text="{DynamicResource AboutRepositoryTitle}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8">
                        <Run Text="{DynamicResource AboutRepositoryPrefix}"/>
                        <Hyperlink NavigateUri="https://github.com/PocketMC/pocket-mc-windows.git" RequestNavigate="Hyperlink_RequestNavigate">
                            https://github.com/PocketMC/pocket-mc-windows.git
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Text="{DynamicResource AboutCommunityPrompt}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </ui:Card>

            <!-- COMMUNITY SECTION -->
            <ui:CardExpander IsExpanded="True" Icon="{ui:SymbolIcon People24}" MaxWidth="600" HorizontalAlignment="Left">
                <ui:CardExpander.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Community" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Join our Discord server to get help, share tips, and connect with other PocketMC users." Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </ui:CardExpander.Header>

                <StackPanel Margin="16,8,16,16">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ui:Button Content="{DynamicResource JoinDiscordButton}" Appearance="Primary" Click="OpenDiscord_Click"/>
                        <ui:Button Content="{DynamicResource CopyInviteButton}" Appearance="Secondary" Margin="8,0,0,0" Click="CopyDiscordInvite_Click"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardExpander>
        </StackPanel>
    </Grid>
</Page>