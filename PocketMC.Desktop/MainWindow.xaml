<ui:FluentWindow x:Class="PocketMC.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="PocketMC Desktop" Height="600" Width="1000"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/icon.ico"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ui:TitleBar Title="PocketMC Desktop" Grid.Row="0" VerticalContentAlignment="Center">
            <ui:TitleBar.Header>
                <TextBlock x:Name="GlobalHealthTextBlock" Text="" Margin="0,0,110,0" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="Silver" FontSize="11"/>
            </ui:TitleBar.Header>
        </ui:TitleBar>
        <Frame x:Name="RootFrame" Grid.Row="1" NavigationUIVisibility="Hidden" JournalOwnership="OwnsJournal"/>
    </Grid>
</ui:FluentWindow>
