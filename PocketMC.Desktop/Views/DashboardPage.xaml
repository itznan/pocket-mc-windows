<Page x:Class="PocketMC.Desktop.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Dashboard">
    
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>
    
    <Grid Margin="24" AllowDrop="True" Drop="Page_Drop" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <ui:TextBlock FontTypography="Title" Text="Instances" Foreground="White" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <ui:Button Content="New Instance" Icon="{ui:SymbolIcon Add24}" Appearance="Primary" Command="{Binding DataContext.NewInstanceCommand, RelativeSource={RelativeSource AncestorType=Page}}" Cursor="Hand" Margin="0,0,8,0"/>            </StackPanel>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Left">
                <ItemsControl x:Name="InstanceGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Outer Border for green glow — ui:Card ignores BorderBrush overrides -->
                            <Border Margin="0,0,16,16" CornerRadius="8" Padding="0" Width="340" MinWidth="280" MinHeight="180">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ui:Card Cursor="Hand" Padding="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                    <Grid Margin="16">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/> <!-- Title & Menu -->
                                            <RowDefinition Height="Auto"/> <!-- Description -->
                                            <RowDefinition Height="Auto"/> <!-- Status & Tunnel Pill -->
                                            <RowDefinition Height="Auto"/> <!-- Running Metrics Panel -->
                                            <RowDefinition Height="*"/>    <!-- Spacer -->
                                            <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                                        </Grid.RowDefinitions>
                                
                                <!-- Title row (Row 0) -->
                                <Grid Grid.Row="0" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:TextBlock FontTypography="Subtitle" Text="{Binding Name}" MaxWidth="150" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                                        <Border Background="#33FFFFFF" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding MinecraftVersion, FallbackValue='?'}" FontSize="10" Foreground="Silver" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Background="#3389B4FA" CornerRadius="4" Padding="6,2" Margin="4,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ServerType, FallbackValue='Vanilla'}" FontSize="10" Foreground="#89B4FA" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    
                                    <ui:Button Grid.Column="1" Appearance="Transparent" Icon="{ui:SymbolIcon MoreVertical24}" 
                                               Click="BtnMoreOptions_Click" Cursor="Hand" Padding="6,4" Margin="0,-6,-6,0" VerticalAlignment="Top">
                                        <ui:Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Rename Instance" Command="{Binding DataContext.RenameInstanceCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" />
                                                <Separator/>
                                                <MenuItem Header="Copy Crash Report" Command="{Binding DataContext.CopyCrashReportCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" />
                                                <MenuItem Header="Open Instance Folder" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" />
                                                <Separator/>
                                                <MenuItem Header="Delete Instance" Command="{Binding DataContext.DeleteInstanceCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" />
                                            </ContextMenu>
                                        </ui:Button.ContextMenu>
                                    </ui:Button>
                                </Grid>
                                
                                <!-- Description (Row 1) -->
                                <ui:TextBlock Grid.Row="1" FontTypography="Caption" Text="{Binding Description}" 
                                              Foreground="Silver" Height="34"
                                              TextWrapping="Wrap" Margin="0,0,0,12" TextTrimming="CharacterEllipsis"/>
                                              
                                <!-- Status & Tunnel Pill (Row 2) -->
                                <Grid Grid.Row="2" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0" Text="{Binding StatusText}" 
                                               Foreground="{Binding StatusColor}" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                               
                                    <Border Grid.Column="1" Background="#2089B4FA" CornerRadius="10" Padding="8,3"
                                            Cursor="Hand" Visibility="{Binding HasTunnelAddress, Converter={StaticResource BoolToVis}}">
                                        <Border.InputBindings>
                                            <MouseBinding Gesture="LeftClick" Command="{x:Null}"/>
                                        </Border.InputBindings>
                                        <TextBlock Text="{Binding TunnelAddress}" FontSize="10" 
                                                   Foreground="#89B4FA" FontWeight="SemiBold"
                                                   MouseLeftButtonDown="TunnelPill_MouseDown"/>
                                    </Border>
                                </Grid>
                                
                                <!-- Running metrics panel (Row 3, hidden when stopped) -->
                                <Grid Grid.Row="3" Visibility="{Binding RunningControlsVisibility}" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CpuText}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Margin="0,0,16,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding RamText}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                                    </StackPanel>
                                    
                                    <!-- Player count -->
                                    <TextBlock Grid.Column="2" Text="{Binding PlayerStatus}" FontSize="11" FontWeight="Medium" 
                                               Foreground="{Binding StatusColor}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>

                                <!-- Action buttons (Row 5) -->
                                <Grid Grid.Row="5" Margin="0,8,0,0">
                                    <!-- STOPPED state -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Visibility="{Binding StoppedControlsVisibility}">
                                        <ui:Button Content="Start" Appearance="Primary" Margin="0,0,4,0"
                                                   Icon="{ui:SymbolIcon Play24}" Command="{Binding DataContext.StartServerCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Cursor="Hand"/>
                                        <ui:Button Content="Logs" Appearance="Secondary" Margin="0,0,4,0"
                                                   Icon="{ui:SymbolIcon WindowConsole20}" Command="{Binding DataContext.OpenConsoleCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Cursor="Hand"/>
                                        <ui:Button Content="Settings" Appearance="Secondary" Margin="0,0,4,0"
                                                   Icon="{ui:SymbolIcon Settings24}" Command="{Binding DataContext.ServerSettingsCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Cursor="Hand"/>
                                        <ui:Button Icon="{ui:SymbolIcon Folder24}" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Cursor="Hand"/>
                                    </StackPanel>
                                    
                                    <!-- RUNNING state -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Visibility="{Binding RunningControlsVisibility}">
                                        <ui:Button Content="{Binding StopButtonText}" Appearance="Danger" Margin="0,0,4,0"
                                                   Icon="{ui:SymbolIcon Stop24}" Command="{Binding DataContext.StopServerCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Cursor="Hand"/>
                                        <ui:Button Content="Console" Appearance="Primary" Margin="0,0,4,0"
                                                   Icon="{ui:SymbolIcon WindowConsole20}" Command="{Binding DataContext.OpenConsoleCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Cursor="Hand"/>
                                        <ui:Button Content="Settings" Appearance="Secondary" Margin="0,0,4,0"
                                                   Icon="{ui:SymbolIcon Settings24}" Command="{Binding DataContext.ServerSettingsCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Cursor="Hand"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </ui:Card>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock x:Name="TxtEmpty" Text="No servers yet. Click 'New Instance' to get started." 
                           Foreground="Silver" HorizontalAlignment="Left" Margin="40" FontSize="14" Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
